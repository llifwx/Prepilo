# Application
APP_ENV=local                          # local | staging | production

# Database
DATABASE_URL=sqlite:///./prepilo.db    # local only; use PostgreSQL in staging/production
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/prepilo

# Security — generate with: openssl rand -hex 32
SECRET_KEY=replace-with-a-random-64-char-hex-string-minimum-32-chars

# Token lifetime in minutes (default: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000
# ALLOWED_ORIGINS=https://prepilo.app,https://www.prepilo.app
